# Enclaude — environment configuration
# Copy to .env and adjust to your machine. Never commit .env.

# Memory cap for the container (e.g. 4g, 8g, 16g)
SANDBOX_MEMORY_LIMIT=8g

# Number of vCPUs available to the container
SANDBOX_CPU_LIMIT=4

# ── n8n MCP Server (optional) ─────────────────────────────
# Connect Claude Code to your n8n instance via MCP.
# Set N8N_MCP_TOKEN to enable. Leave empty to disable.
N8N_MCP_TOKEN=

# MCP endpoint URL
# Examples:
#   N8N_MCP_URL=https://your-n8n-instance.example.com/mcp-server/http
#   N8N_MCP_URL=http://n8n:5678/mcp-server/http  (Docker-local on shared network)
N8N_MCP_URL=
