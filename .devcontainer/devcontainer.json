{
  "name": "Enclaude",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "claude-code",
  "workspaceFolder": "/workspace",
  "remoteUser": "claude",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "claude --version",
  "forwardPorts": []
}
