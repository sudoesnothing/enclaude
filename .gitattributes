# Enforce LF line endings for files that run on Linux
*.sh        text eol=lf
*.py        text eol=lf
Dockerfile  text eol=lf

# Windows scripts keep CRLF
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Config files — LF everywhere
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.env*      text eol=lf
.gitignore  text eol=lf
